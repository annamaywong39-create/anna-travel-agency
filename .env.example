#  ANNA TRAVEL AGENCY — Environment Variables
# ══════════════════════════════════════════════

# Supabase (https://supabase.com → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-key

# Stripe (https://stripe.com → Developers → API Keys)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key_here

# NOTE: Secret keys (Stripe secret, Resend API key) go on the BACKEND only
# Never put secret keys in VITE_ variables — they are exposed to the browser!
